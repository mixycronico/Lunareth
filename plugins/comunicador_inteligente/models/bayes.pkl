import pickle
from sklearn.naive_bayes import GaussianNB

X = [[0.1], [0.5], [0.9]]
y = ["bajo", "medio", "alto"]

modelo = GaussianNB()
modelo.fit(X, y)

with open("plugins/comunicador_inteligente/models/bayes.pkl", "wb") as f:
    pickle.dump(modelo, f)

print("Modelo Bayes reentrenado y guardado.")
